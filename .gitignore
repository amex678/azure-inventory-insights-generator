# ====================================================================
# Azure Inventory & Insights Reports — .gitignore
# ====================================================================

# --------------------------------------------------------------------
# 生成成果物（顧客環境固有の情報を含むためコミット禁止）
# --------------------------------------------------------------------
output/*
!output/.gitkeep

# --------------------------------------------------------------------
# Azure / PowerShell の認証情報・コンテキスト
# --------------------------------------------------------------------
*.publishsettings
*.pfx
*.cer
*.key
.azure/
AzureProfile.json
TokenCache.dat

# --------------------------------------------------------------------
# 環境変数 / シークレット
# --------------------------------------------------------------------
.env
.env.*
!.env.example
secrets.json
appsettings.*.json
!appsettings.example.json

# --------------------------------------------------------------------
# PowerShell
# --------------------------------------------------------------------
*.ps1xml.bak
PSScriptAnalyzerSettings.psd1.bak

# --------------------------------------------------------------------
# OS / エディタ
# --------------------------------------------------------------------
# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Linux
*~
.fuse_hidden*
.directory
.Trash-*

# --------------------------------------------------------------------
# VS Code
# --------------------------------------------------------------------
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/launch.json
!.vscode/tasks.json
*.code-workspace
.history/

# --------------------------------------------------------------------
# JetBrains / その他
# --------------------------------------------------------------------
.idea/
*.swp
*.swo

# --------------------------------------------------------------------
# ログ / 一時ファイル
# --------------------------------------------------------------------
*.log
*.tmp
*.temp
*.bak
*.orig
